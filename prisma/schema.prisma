generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StudentSkill {
  id        String   @id @default(cuid())
  studentId String
  skillName String
  progress  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, skillName])
  @@map("student_skills")
}
